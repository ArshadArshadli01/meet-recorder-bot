{
  "name": "meet-bot-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Self-contained Meet recording worker — consumes BullMQ jobs from Redis. Drop into any backend that enqueues compatible jobs (see README.md and src/types.ts).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-migrations.mjs",
    "start": "node dist/worker.js",
    "dev": "tsx watch src/worker.ts",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:built": "node dist/db/migrate.js",
    "ffmpeg": "node ffmpeg.mjs",
    "ffmpeg:wasapi-devices": "node ffmpeg.mjs -list_devices true -f wasapi -i dummy",
    "ffmpeg:dshow-devices": "node ffmpeg.mjs -f dshow -list_devices true -i dummy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "bullmq": "^5.34.5",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.3.0",
    "firebase-admin": "^13.6.0",
    "ioredis": "^5.4.2",
    "mysql2": "^3.15.3",
    "playwright": "1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
