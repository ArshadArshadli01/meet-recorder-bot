# =============================================================================
# minimal.env — Demo Mode (Local Testing)
# Copy to ".env" to test recording without Google OAuth or S3.
# =============================================================================

PORT=3000
DASHBOARD_PORT=4000
PUBLIC_BASE_URL=http://localhost:3000
DASHBOARD_ORIGIN=http://localhost:4000

# Demo Mode: Bypasses real Google OAuth and S3 requirements
APP_DEMO_MODE=true

DB_PORT=3307
REDIS_EXTERNAL_PORT=6380
REDIS_URL=redis://127.0.0.1:6380
DATA_DIR=./data

# Browser settings
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
HEADLESS=false
WORKER_CONCURRENCY=2

# Windows FFmpeg Path (Update this to your actual ffmpeg.exe path)
MEET_FFMPEG_PATH=C:/Users/Admin/AppData/Local/Microsoft/WinGet/Packages/Gyan.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe/ffmpeg-8.1-full_build/bin/ffmpeg.exe
MEET_WINDOWS_AUDIO=dshow

# Cap recording length
MEETING_MAX_SECONDS=36000

# MySQL (Default for Docker)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USERNAME=root
DB_PASSWORD=meetbot
DB_DATABASE=meet_bot

# Placeholder secrets (Not needed when APP_DEMO_MODE=true)
INTERNAL_API_KEY=demo-secret-key
SESSION_SECRET=placeholder-session-secret
TOKEN_ENC_KEY=placeholder-token-key
DATA_ENC_KEY=placeholder-data-key
