{
  "info": {
    "_postman_id": "a1b2c3d4-meet-bot-api",
    "name": "Meet Bot",
    "description": "API for the Google Meet recorder.\n\n### Authentication Modes\n\n1. **Internal API Key (Operator/Admin)**\n   - Used for legacy routes like `/queue`, `/bots` (admin view), and anonymous bot creation.\n   - **How to get it:** Generate a 32-byte hex string using `openssl rand -hex 32`.\n   - **Configuration:** Set `INTERNAL_API_KEY` in your `.env` file on the server.\n   - **Usage:** Set the `internalApiKey` collection variable to this value. Requests will send it as `Authorization: Bearer {{internalApiKey}}`.\n\n2. **Session Cookie (Dashboard User)**\n   - Used for `/me/*` routes.\n   - **Requirement:** User must be logged in via Google OAuth on the dashboard.\n   - **Scope:** Users only see and manage their own bots and recordings.\n\nSet `baseUrl` (default http://localhost:3000).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "botId", "value": "" },
    { "key": "internalApiKey", "value": "", "description": "Generate with 'openssl rand -hex 32' and set in .env as INTERNAL_API_KEY" }
  ],
  "item": [
    {
      "name": "Admin / Operator Routes",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "Queue stats (debug)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/queue",
            "description": "Shows BullMQ job counts. Requires INTERNAL_API_KEY."
          }
        },
        {
          "name": "List all bots",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/bots?limit=100",
            "description": "Lists all jobs in the system. Requires INTERNAL_API_KEY."
          }
        },
        {
          "name": "Clear entire queue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/queue/clear",
            "description": "Destroys all BullMQ jobs. Requires INTERNAL_API_KEY."
          }
        },
        {
          "name": "Create bot (anonymous)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meeting_url\": \"https://meet.google.com/xxx-yyyy-zzz\",\n  \"bot_name\": \"Meet Bot\"\n}"
            },
            "url": "{{baseUrl}}/bots",
            "description": "Anonymous bot creation. Requires INTERNAL_API_KEY in production."
          }
        }
      ]
    },
    {
      "name": "User Routes (Cookie Auth)",
      "item": [
        {
          "name": "My Bots",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/me/bots",
            "description": "Lists bots owned by the logged-in user. Requires session cookie."
          }
        },
        {
          "name": "Create my bot",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meeting_url\": \"https://meet.google.com/xxx-yyyy-zzz\",\n  \"bot_name\": \"My Bot\"\n}"
            },
            "url": "{{baseUrl}}/me/bots",
            "description": "Creates a bot for the logged-in user. Requires session cookie."
          }
        }
      ]
    },
    {
      "name": "Bot Management (Key or Cookie)",
      "item": [
        {
          "name": "Get bot status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/bots/{{botId}}",
            "description": "Requires job owner session cookie OR INTERNAL_API_KEY."
          }
        },
        {
          "name": "Get recording",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/bots/{{botId}}/recording",
            "description": "Same auth as status."
          }
        },
        {
          "name": "Cancel recording",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/bots/{{botId}}/cancel",
            "description": "Same auth as status."
          }
        },
        {
          "name": "Delete bot job",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{internalApiKey}}", "type": "text" }
            ],
            "url": "{{baseUrl}}/bots/{{botId}}",
            "description": "Same auth as status."
          }
        }
      ]
    }
  ]
}
