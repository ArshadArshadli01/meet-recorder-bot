# =============================================================================
# meet-bot — copy to ".env" and fill in secrets. Defaults: apps/api/src/config.ts
# Quick start: REDIS_URL + DATA_DIR, then npm ci && npm run build; start API + worker.
# Docker: if image pull fails, use docker-compose.redis.yml; set REDIS_URL=redis://127.0.0.1:6379
# =============================================================================

# -----------------------------------------------------------------------------
# PORT — API HTTP listen port (Fastify)
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# DASHBOARD — Next.js app URL/port (CORS, links). DASHBOARD_ORIGIN defaults to
# http://localhost:${DASHBOARD_PORT} if unset.
# -----------------------------------------------------------------------------
DASHBOARD_PORT=4000
DASHBOARD_ORIGIN=http://localhost:4000

# -----------------------------------------------------------------------------
# REDIS — BullMQ backend. If REDIS_URL is set, it wins; otherwise host/port/password
# are combined into redis://[password@]host:port
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Use "null" or leave empty for no password
REDIS_PASSWORD=null

# -----------------------------------------------------------------------------
# DATA_DIR — required on disk: recordings and job artifacts live under
# {DATA_DIR}/recordings. Docker often uses /data.
# QUEUE_NAME — BullMQ queue id shared by API and worker (must match).
# -----------------------------------------------------------------------------
DATA_DIR=./data
QUEUE_NAME=meet-record

# -----------------------------------------------------------------------------
# WORKER_CONCURRENCY — BullMQ: how many jobs one worker **process** runs at once (default 1).
# Each recording ≈ Chromium + ffmpeg + RAM. Scale with multiple worker containers/replicas,
# not only this number. Example: 3 worker replicas × concurrency 1 ⇒ ~3 parallel recordings.
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=1

# -----------------------------------------------------------------------------
# MEETING — hard cap on call length, how often we poll for “meeting ended”, and
# join wait. MEETING_LEAVE_GONE_POLLS reduces false positives from UI flicker.
# -----------------------------------------------------------------------------
MEETING_MAX_SECONDS=36000
MEETING_END_POLL_MS=2500
MEETING_LEAVE_GONE_POLLS=3
JOIN_TIMEOUT_SECONDS=300

# -----------------------------------------------------------------------------
# VIDEO — browser viewport; also Linux x11grab size when using x11 capture.
# -----------------------------------------------------------------------------
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080

# -----------------------------------------------------------------------------
# MEET_* — Google Meet automation (Playwright). HEADLESS: omit or true except when
# debugging on Windows (HEADLESS=false enables fullscreen/F11-style flows).
# MEET_USE_FAKE_MEDIA: fake mic/camera Chromium flags (disable only for real devices).
# MEET_GOTO_*: first navigation to Meet. MEET_STEALTH: playwright-extra stealth plugin.
# MEET_USER_AGENT: optional override (defaults differ Windows vs Linux).
# -----------------------------------------------------------------------------
HEADLESS=true
MEET_USE_FAKE_MEDIA=true
MEET_GOTO_TIMEOUT_MS=120000
# MEET_GOTO_WAIT_UNTIL: commit | domcontentloaded | load | networkidle
MEET_GOTO_WAIT_UNTIL=networkidle
MEET_STEALTH=true
# MEET_USER_AGENT=

# -----------------------------------------------------------------------------
# MEET_* — after join: fullscreen/kiosk, hiding controls, bottom crop (pixels).
# Prefer MEET_RECORDING_CROP_BOTTOM_PX for a clean strip vs fragile CSS hide.
# -----------------------------------------------------------------------------
MEET_RECORDING_FULLSCREEN=true
MEET_RECORDING_KIOSK=false
MEET_HIDE_MEET_CONTROLS_CSS=true
MEET_RECORDING_CROP_BOTTOM_PX=0

# -----------------------------------------------------------------------------
# MEET_LINUX_RECORD_MODE — Linux only: "playwright" = viewport WebM + optional mux;
# "x11" = ffmpeg desktop capture (meetingbot-style).
# -----------------------------------------------------------------------------
MEET_LINUX_RECORD_MODE=playwright

# -----------------------------------------------------------------------------
# MEET_ARTIFACT_* — optional extras during recording: chat JSONL,
# extra M4A when Linux x11+pulse path is on (MEET_ARTIFACT_SEPARATE_AUDIO=true).
# -----------------------------------------------------------------------------
MEET_ARTIFACT_CHAT=true
MEET_ARTIFACT_CHAT_POLL_MS=4000
MEET_ARTIFACT_SEPARATE_AUDIO=false

# -----------------------------------------------------------------------------
# MEET_AUDIO_MUX — mux WAV into WebM → MP4 after job if meet-audio.wav exists.
# MEET_CAPTURE_AUDIO — parallel ffmpeg capture during the call (Pulse / WASAPI / dshow).
# MEET_PLAYBACK_AUDIO_ONLY — Windows dshow: refuse devices that look like mics.
# MEET_FFMPEG_PATH — empty = resolve "ffmpeg" on PATH; Docker needs system ffmpeg for Pulse.
# MEET_PULSE_SOURCE — Linux: pulse monitor device (Docker may set .monitor sink).
# MEET_WINDOWS_AUDIO — wasapi | dshow (many Windows FFmpeg builds lack WASAPI → use dshow).
# MEET_WASAPI_DEVICE — Windows wasapi input (e.g. loopback); ignored when dshow.
# MEET_DSHOW_AUDIO — required for dshow: device name from npm run ffmpeg:dshow-devices
# -----------------------------------------------------------------------------
MEET_AUDIO_MUX=true
MEET_CAPTURE_AUDIO=true
MEET_PLAYBACK_AUDIO_ONLY=true
MEET_FFMPEG_PATH=
MEET_PULSE_SOURCE=default
MEET_WINDOWS_AUDIO=wasapi
MEET_WASAPI_DEVICE=
MEET_DSHOW_AUDIO=

# -----------------------------------------------------------------------------
# BULLMQ — job lock / stall detection. Short locks cause "stalled" on long Meet runs.
# -----------------------------------------------------------------------------
BULLMQ_LOCK_DURATION_MS=600000
BULLMQ_STALLED_INTERVAL_MS=120000
BULLMQ_MAX_STALLED_COUNT=10

# -----------------------------------------------------------------------------
# DO_SPACES_* — DigitalOcean Spaces (S3). Uploads disabled if KEY/SECRET/BUCKET empty.
# Region defaults fra1. ENDPOINT/PUBLIC_URL default from region + bucket if omitted.
# -----------------------------------------------------------------------------
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_REGION=fra1
# DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
# DO_SPACES_PUBLIC_URL=https://your-bucket.fra1.digitaloceanspaces.com

# -----------------------------------------------------------------------------
# INTERNAL_API_KEY — optional shared secret for legacy HTTP routes (/queue, GET /bots, anonymous
# POST /bots, cancel/delete). Send as Authorization: Bearer <token> or X-API-Key. Omit only on
# trusted localhost. Production: generate with openssl rand -hex 32 and set this; dashboard users
# should prefer cookie-auth POST /me/bots instead of anonymous /bots.
# INTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# APP_DEMO_MODE — When true, mocks login and bypasses real OAuth/S3 requirements.
# Set to true for quick local testing of the recording flow.
# -----------------------------------------------------------------------------
APP_DEMO_MODE=false

# -----------------------------------------------------------------------------
# PUBLIC_BASE_URL — OAuth redirect + cookie scope; must match Google Console exactly.
# GOOGLE_* — OAuth web client (all required for dashboard login + TOKEN_ENC_KEY etc.).
# SESSION_SECRET — signed cookies (openssl rand -hex 32).
# TOKEN_ENC_KEY — AES-GCM for refresh tokens in Redis (openssl rand -base64 32).
# DATA_ENC_* — app-layer encryption for MySQL fields; version tag for key rotation.
# -----------------------------------------------------------------------------
PUBLIC_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
TOKEN_ENC_KEY=
DATA_ENC_KEY=
DATA_ENC_KEY_VERSION=v1

# -----------------------------------------------------------------------------
# DB_* / MYSQL_* — MySQL. Code prefers DB_*; MYSQL_* is fallback. MYSQL_SSL=true for TLS.
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=meet_bot
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=meet_bot
MYSQL_SSL=false

# -----------------------------------------------------------------------------
# FCM_* — Firebase Admin push (server). PEM in FCM_PRIVATE_KEY; use \n for newlines in .env
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_* — baked into the dashboard at build time. Firebase web config + API URL.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# =============================================================================
# Notes
# =============================================================================
# Auth: all of GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, SESSION_SECRET, TOKEN_ENC_KEY must
#   be set for dashboard login; see docs/google-cloud-setup.md and docs/DEPLOYMENT.md.
# Set INTERNAL_API_KEY in production so public callers cannot use legacy /queue or /bots without
#   the secret or a signed-in session (see apps/api server routes).
# Windows audio: WASAPI needs FFmpeg with wasapi; else MEET_WINDOWS_AUDIO=dshow + Stereo Mix / VB-Cable.
# Bottom bar in video: increase MEET_RECORDING_CROP_BOTTOM_PX (e.g. 72–88 at 720p).
